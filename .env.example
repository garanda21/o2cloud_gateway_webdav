APP_HOST=0.0.0.0
APP_PORT=8080
APP_BASE_URL=http://localhost:8088
APP_ENCRYPTION_KEY_FILE=

CLOUD_PROVIDER=simulated
SIMULATED_ROOT=/data/simulated

O2_API_BASE_URL=https://cloud.o2online.es/sapi/
O2_UPLOAD_BASE_URL=https://upload.cloud.o2online.es/sapi/
O2_LOGIN_URL=https://cloud.o2online.es/
O2_SESSION_FILE=/config/secrets/o2-session.json
O2_PLAYWRIGHT_HEADLESS=false

WEBDAV_ENABLED=true
WEBDAV_PATH_BASE=/dav
WEBDAV_USERNAME=o2dav
WEBDAV_PASSWORD=
WEBDAV_PASSWORD_FILE=/run/secrets/webdav_password
WEBDAV_READ_ONLY=false
WEBDAV_ALLOW_DOTFILES=true
WEBDAV_DEPTH_INFINITY=false

ADMIN_ENABLED=true
ADMIN_PATH_BASE=/admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_PASSWORD_FILE=/run/secrets/admin_password
ADMIN_SESSION_SECRET_FILE=/run/secrets/app_encryption_key

CONFIG_DIR=/config
CACHE_DIR=/cache
DATA_DIR=/data
SQLITE_PATH=/data/o2cloud-gateway.db

CACHE_METADATA_TTL_SECONDS=20
CACHE_NEGATIVE_TTL_SECONDS=5
CACHE_MAX_SIZE_MB=4096

UPLOAD_MAX_FILE_MB=10240
UPLOAD_SPOOL_DIR=/cache/uploads

DOWNLOAD_TIMEOUT_SECONDS=3600
O2_HTTP_TIMEOUT_SECONDS=120

LOG_LEVEL=INFO
LOG_FILE=/data/logs/gateway.log

